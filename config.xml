<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets" xmlns:tizen="http://tizen.org/ns/widgets" id="http://tizen.org/NuvioTizenWrapper" version="0.1.4" viewmodes="fullscreen">
    <tizen:application id="gKxbY2Kj1R.NuvioTizenWrapper" package="gKxbY2Kj1R" required_version="2.3"/>
    <content src="index.html"/>
    <feature name="http://tizen.org/feature/screen.size.all"/>
    <icon src="icon.png"/>
    <name>Nuvio TV</name>
    <tizen:profile name="tv-samsung"/>
    <tizen:setting screen-orientation="landscape" context-menu="disable" background-support="disable" encryption="disable" install-location="auto" hwkey-event="enable"/>
    
    <!-- CRITICAL: Permissions to talk to the ecosystem -->
    <access origin="*" subdomains="true"/>
    <tizen:privilege name="http://tizen.org/privilege/internet"/>
    <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>
    <tizen:privilege name="http://tizen.org/privilege/download"/>
    
    <tizen:metadata key="http://samsung.com/tv/metadata/devel.mode" value="true"/>
</widget>
